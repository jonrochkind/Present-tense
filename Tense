            fontFamily: "Georgia, serif",
            opacity: (!task.trim() || !minutes) ? 0.4 : 1,
            marginTop: 4,
          }}
        >
          Begin
        </button>
      </div>
    )}

    {(phase === "running" || phase === "done") && (
      <div style={{ display: "flex", flexDirection: "column", gap: 24, alignItems: "center" }}>
        {/* Task label */}
        <div style={{ textAlign: "center" }}>
          <div
            style={{
              fontSize: 11,
              letterSpacing: 3,
              color: COLORS.faded,
              textTransform: "uppercase",
              marginBottom: 6,
            }}
          >
            {isDone ? "Completed" : paused ? "Paused" : "Now"}
          </div>
          <div style={{ fontSize: 17, color: COLORS.ink, lineHeight: 1.4 }}>
            {taskRef.current}
          </div>
        </div>

        <CircularTimer
          progress={progress}
          timeLeft={timeLeft}
          total={total}
          paused={paused}
          done={isDone}
        />

        {isDone && (
          <div
            style={{
              background: "#EAF4EF",
              border: `1px solid ${COLORS.done}`,
              borderRadius: 4,
              padding: "10px 16px",
              fontSize: 13,
              color: COLORS.done,
              letterSpacing: 1,
              textAlign: "center",
            }}
          >
            Time's up.
          </div>
        )}

        <div style={{ display: "flex", gap: 10, width: "100%" }}>
          {!isDone && (
            <button
              onClick={handlePause}
              style={{
                flex: 1,
                background: COLORS.bg,
                border: `1.5px solid ${COLORS.ring}`,
                borderRadius: 4,
                padding: "11px",
                fontSize: 12,
                letterSpacing: 2,
                textTransform: "uppercase",
                cursor: "pointer",
                color: COLORS.ink,
                fontFamily: "Georgia, serif",
              }}
            >
              {paused ? "Resume" : "Pause"}
            </button>
          )}
          <button
            onClick={handleDone}
            style={{
              flex: 1,
              background: isDone ? COLORS.done : COLORS.accent,
              color: "#fff",
              border: "none",
              borderRadius: 4,
              padding: "11px",
              fontSize: 12,
              letterSpacing: 2,
