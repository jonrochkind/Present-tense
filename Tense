import { useState, useEffect, useRef, useCallback } from “react”;

const COLORS = {
bg: “#F5F0E8”,
paper: “#FDFAF4”,
ink: “#1C1A16”,
faded: “#8C8070”,
accent: “#C94A2A”,
accentLight: “#E8D5CF”,
ring: “#D4C9B8”,
done: “#3A7A5C”,
};

const pad = (n) => String(n).padStart(2, “0”);

function CircularTimer({ progress, timeLeft, total, paused, done }) {
const r = 90;
const circ = 2 * Math.PI * r;
const offset = circ * (1 - progress);

const mins = Math.floor(timeLeft / 60);
const secs = timeLeft % 60;

return (
<div style={{ position: “relative”, width: 220, height: 220, margin: “0 auto” }}>
<svg width=“220” height=“220” style={{ transform: “rotate(-90deg)” }}>
<circle cx="110" cy="110" r={r} fill="none" stroke={COLORS.ring} strokeWidth="10" />
<circle
cx=“110”
cy=“110”
r={r}
fill=“none”
stroke={done ? COLORS.done : COLORS.accent}
strokeWidth=“10”
strokeDasharray={circ}
strokeDashoffset={offset}
strokeLinecap=“round”
style={{ transition: paused ? “none” : “stroke-dashoffset 1s linear” }}
/>
</svg>
<div
style={{
position: “absolute”,
inset: 0,
display: “flex”,
flexDirection: “column”,
alignItems: “center”,
justifyContent: “center”,
gap: 2,
}}
>
<span
style={{
fontFamily: “‘Courier New’, monospace”,
fontSize: 42,
fontWeight: “bold”,
color: done ? COLORS.done : COLORS.ink,
letterSpacing: “-2px”,
lineHeight: 1,
}}
>
{pad(mins)}:{pad(secs)}
</span>
{total > 0 && (
<span style={{ fontFamily: “Georgia, serif”, fontSize: 11, color: COLORS.faded }}>
of {Math.floor(total / 60)} min
</span>
)}
</div>
</div>
);
}

function exportMarkdown(history) {
const today = new Date().toLocaleDateString(“en-US”, { weekday: “long”, year: “numeric”, month: “long”, day: “numeric” });
const totalSecs = history.reduce((sum, h) => sum + h.elapsed, 0);
const totalMins = Math.floor(totalSecs / 60);
const totalRemSecs = totalSecs % 60;

const lines = [
`- ${today}`,
`\t- Total focused time: ${totalMins}m ${totalRemSecs}s`,
…history.slice().reverse().map((h) => {
const m = Math.floor(h.elapsed / 60);
const s = h.elapsed % 60;
return `\t\t- ${h.task} :: ${m}m ${s}s`;
}),
];

const blob = new Blob([lines.join(”\n”)], { type: “text/markdown” });
const url = URL.createObjectURL(blob);
const a = document.createElement(“a”);
a.href = url;
a.download = `present-tense-${new Date().toISOString().slice(0, 10)}.md`;
a.click();
URL.revokeObjectURL(url);
}

function TaskCard({ task, elapsed, onClose }) {
return (
<div
style={{
background: COLORS.paper,
border: `1.5px solid ${COLORS.ring}`,
borderRadius: 4,
padding: “8px 14px”,
display: “flex”,
justifyContent: “space-between”,
alignItems: “center”,
gap: 12,
}}
>
<div style={{ display: “flex”, alignItems: “center”, gap: 10 }}>
<span style={{ color: COLORS.done, fontSize: 14 }}>✓</span>
<span style={{ fontFamily: “Georgia, serif”, fontSize: 13, color: COLORS.ink }}>{task}</span>
</div>
<span style={{ fontFamily: “‘Courier New’, monospace”, fontSize: 11, color: COLORS.faded, whiteSpace: “nowrap” }}>
{Math.floor(elapsed / 60)}m {elapsed % 60}s
</span>
</div>
);
}

export default function App() {
const [phase, setPhase] = useState(“entry”); // entry | running | done
const [task, setTask] = useState(””);
const [minutes, setMinutes] = useState(””);
const [timeLeft, setTimeLeft] = useState(0);
const [total, setTotal] = useState(0);
const [paused, setPaused] = useState(false);
const [history, setHistory] = useState([]);
const [elapsed, setElapsed] = useState(0);
const intervalRef = useRef(null);
const taskRef = useRef(””);
const elapsedRef = useRef(0);

const clearTimer = useCallback(() => {
if (intervalRef.current) clearInterval(intervalRef.current);
}, []);

const startCounting = useCallback((startLeft) => {
clearTimer();
intervalRef.current = setInterval(() => {
setTimeLeft((prev) => {
if (prev <= 1) {
clearInterval(intervalRef.current);
setPhase(“done”);
return 0;
}
return prev - 1;
});
elapsedRef.current += 1;
setElapsed((e) => e + 1);
}, 1000);
}, [clearTimer]);

const handleStart = () => {
const mins = parseFloat(minutes);
if (!task.trim() || isNaN(mins) || mins <= 0) return;
const secs = Math.round(mins * 60);
taskRef.current = task.trim();
elapsedRef.current = 0;
setElapsed(0);
setTotal(secs);
setTimeLeft(secs);
setPhase(“running”);
setPaused(false);
startCounting(secs);
};

const handlePause = () => {
if (paused) {
startCounting(timeLeft);
setPaused(false);
} else {
clearTimer();
setPaused(true);
}
};

const handleDone = () => {
clearTimer();
setHistory((h) => [{ task: taskRef.current, elapsed: elapsedRef.current }, …h]);
setPhase(“entry”);
setTask(””);
setMinutes(””);
setTimeLeft(0);
setTotal(0);
setPaused(false);
};

const handleStop = () => {
clearTimer();
setHistory((h) => [{ task: taskRef.current, elapsed: elapsedRef.current }, …h]);
setPhase(“entry”);
setTask(””);
setMinutes(””);
setPaused(false);
};

useEffect(() => {
if (phase === “done”) {
clearTimer();
}
}, [phase, clearTimer]);

useEffect(() => () => clearTimer(), [clearTimer]);

const progress = total > 0 ? timeLeft / total : 0;
const isDone = phase === “done”;

return (
<div
style={{
minHeight: “100vh”,
background: COLORS.bg,
display: “flex”,
flexDirection: “column”,
alignItems: “center”,
justifyContent: “flex-start”,
padding: “40px 20px 60px”,
fontFamily: “Georgia, serif”,
}}
>
{/* Header */}
<div style={{ textAlign: “center”, marginBottom: 36 }}>
<div style={{ fontSize: 11, letterSpacing: 4, color: COLORS.faded, textTransform: “uppercase”, marginBottom: 6 }}>
Present Tense
</div>
<div
style={{
width: 32,
height: 1.5,
background: COLORS.accent,
margin: “0 auto”,
}}
/>
</div>

```
  {/* Main Card */}
  <div
    style={{
      background: COLORS.paper,
      border: `1.5px solid ${COLORS.ring}`,
      borderRadius: 6,
      padding: "36px 32px",
      width: "100%",
      maxWidth: 380,
      boxShadow: "0 2px 24px rgba(0,0,0,0.06), 0 1px 4px rgba(0,0,0,0.04)",
    }}
  >
    {phase === "entry" && (
      <div style={{ display: "flex", flexDirection: "column", gap: 20 }}>
        <div>
          <label
            style={{
              display: "block",
              fontSize: 11,
              letterSpacing: 3,
              color: COLORS.faded,
              textTransform: "uppercase",
              marginBottom: 8,
            }}
          >
            What are you doing?
          </label>
          <textarea
            value={task}
            onChange={(e) => setTask(e.target.value)}
            placeholder="Writing weekly review…"
            rows={2}
            style={{
              width: "100%",
              background: COLORS.bg,
              border: `1px solid ${COLORS.ring}`,
              borderRadius: 4,
              padding: "10px 12px",
              fontFamily: "Georgia, serif",
              fontSize: 15,
              color: COLORS.ink,
